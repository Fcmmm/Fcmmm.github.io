style.
  #music-page { max-width: 900px; margin: 0 auto; padding: 0 16px; }
  .music-hero { position: relative; text-align: center; padding: 48px 20px 36px; margin-bottom: 24px; border-radius: 16px; overflow: hidden; background: linear-gradient(135deg, #49B1F5 0%, #6e45e2 50%, #ff6b9d 100%); }
  .music-hero-content { position: relative; z-index: 1; }
  .music-icon { font-size: 48px; color: rgba(255,255,255,.9); margin-bottom: 12px; animation: musicFloat 3s ease-in-out infinite; }
  @keyframes musicFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  .music-hero h1 { font-size: 32px; font-weight: 700; color: #fff; margin: 0 0 8px; letter-spacing: 2px; }
  .music-desc { font-size: 15px; color: rgba(255,255,255,.85); margin: 0 0 20px; }
  .music-wave { display: flex; align-items: center; justify-content: center; gap: 4px; height: 30px; }
  .music-wave span { display: block; width: 3px; height: 12px; background: rgba(255,255,255,.7); border-radius: 3px; animation: waveAnim 1.2s ease-in-out infinite; }
  .music-wave span:nth-child(1) { animation-delay: 0s; }
  .music-wave span:nth-child(2) { animation-delay: .2s; }
  .music-wave span:nth-child(3) { animation-delay: .4s; }
  .music-wave span:nth-child(4) { animation-delay: .6s; }
  .music-wave span:nth-child(5) { animation-delay: .8s; }
  @keyframes waveAnim { 0%, 100% { height: 12px; } 50% { height: 28px; } }
  .music-container { background: var(--card-bg, #fff); border-radius: 16px; padding: 16px; box-shadow: 0 4px 20px rgba(0,0,0,.06); }
  .music-playlist-loading { text-align:center; padding:40px; color:#999; }
  /* 播放列表每一项 */
  .music-song-item {
    display: flex; align-items: center; gap: 12px; padding: 10px 12px;
    border-radius: 10px; cursor: pointer; transition: background .2s;
    border-bottom: 1px solid var(--border-color, #f0f0f0);
  }
  .music-song-item:hover { background: rgba(73,177,245,.06); }
  .music-song-item.playing { background: rgba(73,177,245,.12); }
  .music-song-index { width: 28px; text-align: center; font-size: 13px; color: #999; flex-shrink: 0; }
  .music-song-item.playing .music-song-index { color: #49B1F5; font-weight: 700; }
  .music-song-info { flex: 1; min-width: 0; }
  .music-song-name { font-size: 14px; font-weight: 500; color: var(--font-color, #333); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .music-song-item.playing .music-song-name { color: #49B1F5; }
  .music-song-artist { font-size: 12px; color: #999; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .music-song-duration { font-size: 12px; color: #bbb; flex-shrink: 0; width: 40px; text-align: right; }
  .music-info { margin-top: 20px; }
  .music-info-card { background: var(--card-bg, #fff); border-radius: 12px; padding: 20px 24px; border: 1px solid var(--border-color, #f0f0f0); }
  .music-info-card h3 { font-size: 16px; margin: 0 0 12px; color: var(--font-color, #333); }
  .music-info-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .music-info-card p { font-size: 13px; color: #999; margin: 0 0 6px; line-height: 1.6; }
  .music-stats { display: flex; gap: 24px; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border-color, #f0f0f0); }
  .music-stat-item { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #888; }
  .music-stat-icon { font-size: 16px; }
  [data-theme="dark"] .music-container { background: #1e1e1e; }
  [data-theme="dark"] .music-info-card { background: #1e1e1e; border-color: #333; }
  [data-theme="dark"] .music-song-item { border-bottom-color: #333; }
  @media screen and (max-width: 768px) {
    .music-hero { padding: 32px 16px 24px; border-radius: 12px; }
    .music-hero h1 { font-size: 24px; }
    .music-container { padding: 10px; border-radius: 12px; }
    .music-stats { gap: 16px; flex-wrap: wrap; }
    .music-song-item { padding: 8px 8px; gap: 8px; }
  }

script.
  var PLAYLIST_ID = '#{page.playlist || "2309860218"}'
  var API_BASE = 'https://fcmmm.xyz/api/music?server=netease'

  // 等待悬浮窗 APlayer 就绪
  function waitForAPlayer(cb, tries) {
    tries = tries || 0
    if (tries > 50) return
    if (window.aplayers && window.aplayers.length) {
      // 找 fixed 那个（悬浮窗）
      var ap = window.aplayers.find(function (p) { return p.options.fixed })
      if (ap) return cb(ap)
    }
    setTimeout(function () { waitForAPlayer(cb, tries + 1) }, 200)
  }

  function formatTime(sec) {
    if (!sec || isNaN(sec)) return '--:--'
    var m = Math.floor(sec / 60)
    var s = Math.floor(sec % 60)
    return m + ':' + (s < 10 ? '0' : '') + s
  }

  // 渲染播放列表
  function renderPlaylist(songs, aplayer) {
    var wrap = document.getElementById('music-playlist-wrap')
    if (!songs.length) {
      wrap.innerHTML = '<p class="music-playlist-loading">暂无歌曲</p>'
      return
    }
    var html = ''
    songs.forEach(function (song, i) {
      html += '<div class="music-song-item" data-index="' + i + '">'
      html += '<span class="music-song-index">' + (i + 1) + '</span>'
      html += '<div class="music-song-info">'
      html += '<div class="music-song-name">' + song.name + '</div>'
      html += '<div class="music-song-artist">' + song.artist + '</div>'
      html += '</div>'
      html += '<span class="music-song-duration">' + formatTime(song.duration) + '</span>'
      html += '</div>'
    })
    wrap.innerHTML = html

    // 点击播放
    wrap.querySelectorAll('.music-song-item').forEach(function (item) {
      item.addEventListener('click', function () {
        var idx = parseInt(this.dataset.index)
        aplayer.list.switch(idx)
        aplayer.play()
        // 如果悬浮窗是折叠的，展开一下
        var fp = document.getElementById('music-float-player')
        if (fp) fp.style.opacity = '1'
      })
    })

    // 高亮当前播放
    function updateActive() {
      var cur = aplayer.list.index
      wrap.querySelectorAll('.music-song-item').forEach(function (item, i) {
        item.classList.toggle('playing', i === cur)
      })
    }
    aplayer.on('listswitch', updateActive)
    updateActive()
  }

  // 从 API 拉取歌单
  function fetchPlaylist() {
    fetch(API_BASE + '&type=playlist&id=' + PLAYLIST_ID)
      .then(function (r) { return r.json() })
      .then(function (songs) {
        if (songs.error) throw new Error(songs.error)
        waitForAPlayer(function (ap) {
          // 将歌曲注入 APlayer（如果还没注入过）
          if (!ap.list.audios || !ap.list.audios.length || ap.list.audios.length !== songs.length) {
            ap.list.clear()
            songs.forEach(function (s) { ap.list.add([s]) })
          }
          renderPlaylist(songs, ap)
        })
      })
      .catch(function (e) {
        document.getElementById('music-playlist-wrap').innerHTML =
          '<p class="music-playlist-loading">歌单加载失败：' + e.message + '</p>'
      })
  }

  // 启动：等 APlayer 就绪后拉歌单
  waitForAPlayer(function () {
    fetchPlaylist()
  })
