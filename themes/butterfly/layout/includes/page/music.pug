//- 音乐馆 — 网易云音乐 + APlayer + MetingJS
#music-page
  .music-hero
    .music-hero-content
      .music-icon
        i.fas.fa-music
      h1 音乐馆
      p.music-desc 网易云音乐 · 我喜欢的音乐
      .music-wave
        span
        span
        span
        span
        span

  .music-container
    #music-player-wrap
      meting-js(
        server="netease"
        type="playlist"
        id=page.playlist || '7455412811'
        api="https://vercel-api-ten-sigma.vercel.app/api/music?server=:server&type=:type&id=:id"
        fixed="false"
        mini="false"
        autoplay="false"
        theme="#49B1F5"
        loop="all"
        order="random"
        preload="auto"
        volume="0.7"
        list-folded="true"
        list-max-height="400px"
        lrc-type="3"
      )

    .music-info
      .music-info-card
        .music-info-header
          h3  关于音乐馆
          button#music-refresh-btn.music-refresh-btn(onclick="refreshPlaylist()")  刷新歌单
        p 这里展示的是我在网易云音乐的「我喜欢的音乐」歌单，数据实时同步。
        p 播放器支持：歌单切换、歌词显示、循环模式、音量调节等功能。
        p.music-note  提示：如遇加载失败，请点击刷新歌单按钮或刷新页面。
        .music-stats
          .music-stat-item
            span.music-stat-icon &#127926;
            span 实时同步
          .music-stat-item
            span.music-stat-icon &#127911;
            span 高音质
          .music-stat-item
            span.music-stat-icon &#128260;
            span 歌词显示

script.
  function refreshPlaylist() {
    var btn = document.getElementById('music-refresh-btn');
    var wrap = document.getElementById('music-player-wrap');
    if (!wrap) return;
    btn.textContent = '⏳ 加载中...';
    btn.disabled = true;
    var oldMeting = wrap.querySelector('meting-js');
    if (oldMeting) oldMeting.remove();
    var oldAplayer = wrap.querySelector('.aplayer');
    if (oldAplayer) oldAplayer.remove();
    var meting = document.createElement('meting-js');
    meting.setAttribute('server', 'netease');
    meting.setAttribute('type', 'playlist');
    meting.setAttribute('id', '#{page.playlist || "7455412811"}');
    meting.setAttribute('api', 'https://vercel-api-ten-sigma.vercel.app/api/music?server=:server&type=:type&id=:id');
    meting.setAttribute('fixed', 'false');
    meting.setAttribute('mini', 'false');
    meting.setAttribute('autoplay', 'false');
    meting.setAttribute('theme', '#49B1F5');
    meting.setAttribute('loop', 'all');
    meting.setAttribute('order', 'random');
    meting.setAttribute('preload', 'auto');
    meting.setAttribute('volume', '0.7');
    meting.setAttribute('list-folded', 'true');
    meting.setAttribute('list-max-height', '400px');
    meting.setAttribute('lrc-type', '3');
    wrap.appendChild(meting);
    // MetingJS v2 是 Web Component，appendChild 会自动触发 connectedCallback 初始化
    setTimeout(function() {
      btn.textContent = ' 刷新歌单';
      btn.disabled = false;
    }, 1500);
  }

  // 监听 APlayer 创建，启用歌词并处理布局
  var musicObserver = new MutationObserver(function (mutations) {
    mutations.forEach(function (m) {
      m.addedNodes.forEach(function (node) {
        if (node.classList && node.classList.contains('aplayer')) {
          node.classList.add('aplayer-withlrc')
          // 监听歌词内容加载
          var lrcObserver = new MutationObserver(function () {
            var lrc = node.querySelector('.aplayer-lrc')
            var content = node.querySelector('.aplayer-lrc-content')
            if (lrc && content && content.children.length > 0) {
              lrc.style.display = 'block'
              lrc.style.height = 'auto'
              lrc.style.maxHeight = '180px'
              lrc.style.overflowY = 'auto'
              content.style.display = 'block'
            }
          })
          lrcObserver.observe(node, { childList: true, subtree: true })
          // 初始检查
          var lrc = node.querySelector('.aplayer-lrc')
          var content = node.querySelector('.aplayer-lrc-content')
          if (lrc && content && content.children.length > 0) {
            lrc.style.display = 'block'
            lrc.style.height = 'auto'
            lrc.style.maxHeight = '180px'
            lrc.style.overflowY = 'auto'
            content.style.display = 'block'
          }
        }
      })
    })
  })
  musicObserver.observe(document.getElementById('music-player-wrap'), { childList: true, subtree: true })

style.
  #music-page { max-width: 900px; margin: 0 auto; padding: 0 16px; }
  .music-hero { position: relative; text-align: center; padding: 48px 20px 36px; margin-bottom: 24px; border-radius: 16px; overflow: hidden; background: linear-gradient(135deg, #49B1F5 0%, #6e45e2 50%, #ff6b9d 100%); }
  .music-hero-content { position: relative; z-index: 1; }
  .music-icon { font-size: 48px; color: rgba(255,255,255,.9); margin-bottom: 12px; animation: musicFloat 3s ease-in-out infinite; }
  @keyframes musicFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  .music-hero h1 { font-size: 32px; font-weight: 700; color: #fff; margin: 0 0 8px; letter-spacing: 2px; }
  .music-desc { font-size: 15px; color: rgba(255,255,255,.85); margin: 0 0 20px; }
  .music-wave { display: flex; align-items: center; justify-content: center; gap: 4px; height: 30px; }
  .music-wave span { display: block; width: 3px; height: 12px; background: rgba(255,255,255,.7); border-radius: 3px; animation: waveAnim 1.2s ease-in-out infinite; }
  .music-wave span:nth-child(1) { animation-delay: 0s; }
  .music-wave span:nth-child(2) { animation-delay: .2s; }
  .music-wave span:nth-child(3) { animation-delay: .4s; }
  .music-wave span:nth-child(4) { animation-delay: .6s; }
  .music-wave span:nth-child(5) { animation-delay: .8s; }
  @keyframes waveAnim { 0%, 100% { height: 12px; } 50% { height: 28px; } }
  .music-container { background: var(--card-bg, #fff); border-radius: 16px; padding: 16px; box-shadow: 0 4px 20px rgba(0,0,0,.06); }
  #music-player-wrap { border-radius: 12px; }
  #music-player-wrap .aplayer { background: var(--card-bg, #fff) !important; border-radius: 12px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  #music-player-wrap .aplayer .aplayer-list ol li { border-top: 1px solid var(--border-color, #f0f0f0) !important; }
  #music-player-wrap .aplayer .aplayer-list ol li:hover { background: rgba(73,177,245,.05) !important; }
  #music-player-wrap .aplayer .aplayer-list ol li.aplayer-list-light { background: rgba(73,177,245,.08) !important; }
  #music-player-wrap .aplayer .aplayer-info .aplayer-music { color: var(--font-color, #333) !important; }
  #music-player-wrap .aplayer .aplayer-lrc { color: var(--font-color, #666) !important; }
  #music-player-wrap .aplayer .aplayer-lrc:before, #music-player-wrap .aplayer .aplayer-lrc:after { background: var(--card-bg, #fff) !important; }
  .music-info { margin-top: 20px; }
  .music-info-card { background: var(--card-bg, #fff); border-radius: 12px; padding: 20px 24px; border: 1px solid var(--border-color, #f0f0f0); }
  .music-info-card h3 { font-size: 16px; margin: 0 0 12px; color: var(--font-color, #333); }
  .music-info-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .music-info-header h3 { margin: 0 !important; }
  .music-refresh-btn { display: inline-flex; align-items: center; gap: 4px; padding: 8px 16px; background: #49B1F5; color: #fff; border: none; border-radius: 8px; font-size: 13px; cursor: pointer; transition: background .2s, transform .2s; white-space: nowrap; }
  .music-refresh-btn:hover { background: #3a8fd4; transform: scale(1.03); }
  .music-refresh-btn:disabled { opacity: .7; cursor: not-allowed; transform: none; }
  .music-info-card p { font-size: 13px; color: #999; margin: 0 0 6px; line-height: 1.6; }
  .music-note { font-style: italic; }
  .music-stats { display: flex; gap: 24px; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border-color, #f0f0f0); }
  .music-stat-item { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #888; }
  .music-stat-icon { font-size: 16px; }
  [data-theme="dark"] #music-player-wrap .aplayer { background: #1e1e1e !important; }
  [data-theme="dark"] .music-container { background: #1e1e1e; }
  [data-theme="dark"] .music-info-card { background: #1e1e1e; border-color: #333; }
  [data-theme="dark"] #music-player-wrap .aplayer .aplayer-list ol li { border-top-color: #333 !important; }
  [data-theme="dark"] #music-player-wrap .aplayer .aplayer-lrc:before, [data-theme="dark"] #music-player-wrap .aplayer .aplayer-lrc:after { background: #1e1e1e !important; }
  @media screen and (max-width: 768px) {
    .music-hero { padding: 32px 16px 24px; border-radius: 12px; }
    .music-hero h1 { font-size: 24px; }
    .music-container { padding: 10px; border-radius: 12px; }
    .music-stats { gap: 16px; flex-wrap: wrap; }
  }
