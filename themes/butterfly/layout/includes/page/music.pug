//- 音乐馆 — 完整播放器 + 歌单列表，与悬浮窗同步
#music-page
  .music-hero
    .music-hero-content
      .music-icon
        i.fas.fa-music
      h1 音乐馆
      p.music-desc 网易云音乐 · 我喜欢的音乐
      .music-wave
        span
        span
        span
        span
        span

  .music-container
    #music-player-wrap
      meting-js(
        server="netease"
        type="playlist"
        id=page.playlist || '7455412811'
        api="https://fcmmm.xyz/api/music?server=:server&type=:type&id=:id"
        fixed="false"
        mini="false"
        autoplay="false"
        theme="#49B1F5"
        loop="all"
        order="random"
        preload="auto"
        volume="0.7"
        list-folded="false"
        list-max-height="900px"
        lrc-type="3"
        data-lrc-type="3"
      )

style.
  #music-page { max-width: 900px; margin: 0 auto; padding: 0 16px; }
  .music-hero { position: relative; text-align: center; padding: 24px 20px 18px; margin-bottom: 16px; border-radius: 12px; overflow: hidden; background: linear-gradient(135deg, #49B1F5 0%, #6e45e2 50%, #ff6b9d 100%); }
  .music-hero-content { position: relative; z-index: 1; }
  .music-icon { font-size: 28px; color: rgba(255,255,255,.9); margin-bottom: 6px; animation: musicFloat 3s ease-in-out infinite; }
  @keyframes musicFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
  .music-hero h1 { font-size: 22px; font-weight: 700; color: #fff; margin: 0 0 4px; letter-spacing: 1px; }
  .music-desc { font-size: 13px; color: rgba(255,255,255,.8); margin: 0 0 12px; }
  .music-wave { display: flex; align-items: center; justify-content: center; gap: 3px; height: 20px; }
  .music-wave span { display: block; width: 3px; height: 8px; background: rgba(255,255,255,.6); border-radius: 3px; animation: waveAnim 1.2s ease-in-out infinite; }
  .music-wave span:nth-child(1) { animation-delay: 0s; }
  .music-wave span:nth-child(2) { animation-delay: .2s; }
  .music-wave span:nth-child(3) { animation-delay: .4s; }
  .music-wave span:nth-child(4) { animation-delay: .6s; }
  .music-wave span:nth-child(5) { animation-delay: .8s; }
  @keyframes waveAnim { 0%, 100% { height: 8px; } 50% { height: 20px; } }
  .music-container { background: var(--card-bg, #fff); border-radius: 16px; padding: 16px; box-shadow: 0 4px 20px rgba(0,0,0,.06); }
  #music-player-wrap { border-radius: 12px; }
  #music-player-wrap .aplayer { background: var(--card-bg, #fff) !important; border-radius: 12px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  #music-player-wrap .aplayer .aplayer-list ol li { border-top: 1px solid var(--border-color, #f0f0f0) !important; }
  #music-player-wrap .aplayer .aplayer-list ol li:hover { background: rgba(73,177,245,.05) !important; }
  #music-player-wrap .aplayer .aplayer-list ol li.aplayer-list-light { background: rgba(73,177,245,.08) !important; }
  #music-player-wrap .aplayer .aplayer-info .aplayer-music { color: var(--font-color, #333) !important; }
  #music-player-wrap .aplayer .aplayer-lrc { color: var(--font-color, #666) !important; }
  #music-player-wrap .aplayer .aplayer-lrc:before, #music-player-wrap .aplayer .aplayer-lrc:after { background: var(--card-bg, #fff) !important; }
  [data-theme="dark"] #music-player-wrap .aplayer { background: #1e1e1e !important; }
  [data-theme="dark"] .music-container { background: #1e1e1e; }
  [data-theme="dark"] #music-player-wrap .aplayer .aplayer-list ol li { border-top-color: #333 !important; }
  [data-theme="dark"] #music-player-wrap .aplayer .aplayer-lrc:before, [data-theme="dark"] #music-player-wrap .aplayer .aplayer-lrc:after { background: #1e1e1e !important; }
  @media screen and (max-width: 768px) {
    .music-hero { padding: 32px 16px 24px; border-radius: 12px; }
    .music-hero h1 { font-size: 24px; }
    .music-container { padding: 10px; border-radius: 12px; }
  }

script.
  (function () {
    // 获取音乐页的 APlayer（非 fixed）
    function getLocalAP() {
      if (window.aplayers) {
        for (var i = 0; i < window.aplayers.length; i++) {
          if (!window.aplayers[i].options.fixed) return window.aplayers[i]
        }
      }
      return null
    }
    // 获取悬浮窗的 APlayer（fixed）
    function getFloatAP() {
      if (window.aplayers) {
        for (var i = 0; i < window.aplayers.length; i++) {
          if (window.aplayers[i].options.fixed) return window.aplayers[i]
        }
      }
      return null
    }

    // 抓取单首歌词（若仍是 URL 则替换为歌词文本）
    function fetchLrc(audio) {
      if (!audio) return
      var lrc = audio.lrc
      if (typeof lrc !== 'string' || lrc.indexOf('http') !== 0) return
      var xhr = new XMLHttpRequest()
      xhr.open('GET', lrc, true)
      xhr.onload = function () {
        if (xhr.status === 200 && xhr.responseText && xhr.responseText !== 'No lyrics') {
          audio.lrc = xhr.responseText
        }
      }
      xhr.send()
    }

    // 预加载附近歌词
    function preloadLrc(ap) {
      if (!ap.list || !ap.list.audios) return
      var audios = ap.list.audios
      var cur = ap.list.index
      for (var i = cur; i < Math.min(cur + 6, audios.length); i++) {
        fetchLrc(audios[i])
      }
    }

    // 等两个播放器都就绪后同步
    var syncDone = false
    var check = setInterval(function () {
      var local = getLocalAP()
      var float = getFloatAP()
      if (!local || !float) return
      clearInterval(check)
      if (syncDone) return
      syncDone = true

      // 预加载歌词
      preloadLrc(local)

      // 切换歌曲时预加载新歌歌词
      local.on('listswitch', function () { preloadLrc(local) })

      // 本地播放 → 悬浮窗暂停（以音乐页为主）
      local.on('play', function () {
        var idx = local.list.index
        if (float.list.audios.length !== local.list.audios.length) {
          float.list.clear()
          float.list.add(local.list.audios)
        }
        float.list.switch(idx)
        float.pause()
      })
      local.on('pause', function () { float.pause() })
      local.on('listswitch', function (e) {
        if (float.list.audios.length !== local.list.audios.length) {
          float.list.clear()
          float.list.add(local.list.audios)
        }
        float.list.switch(e.index)
      })

      // 悬浮窗已在播放 → 仅同步歌单，不自动播放本地
      // 悬浮窗继续播放，本地播放器仅更新歌单和当前歌曲
      if (!float.paused) {
        var fi = float.list.index
        if (local.list.audios.length !== float.list.audios.length) {
          local.list.clear()
          local.list.add(float.list.audios)
        }
        local.list.switch(fi)
        // 不调用 local.play() — 悬浮窗继续播放不受干扰
        preloadLrc(local)
      }
    }, 300)
  })()
