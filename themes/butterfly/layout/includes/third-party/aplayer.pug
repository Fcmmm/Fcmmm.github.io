link(rel='stylesheet' href=url_for(theme.asset.aplayer_css) media="print" onload="this.media='all'")
script(src=url_for(theme.asset.aplayer_js))
script(src=url_for(theme.asset.meting_js))
//- MetingJS v2 是 Web Component，customElements.define() 时自动升级已有元素
//- APlayer 在 meting_js 之前加载，connectedCallback 时 window.APlayer 已就绪
if theme.pjax.enable
  script.
    (() => {
      const destroyAplayer = () => {
        if (window.aplayers) {
          for (let i = 0; i < window.aplayers.length; i++) {
            if (!window.aplayers[i].options.fixed) {
              window.aplayers[i].destroy()
            }
          }
        }
      }

      // MetingJS v2 是 Web Component，PJAX 加载新页面时浏览器自动升级 <meting-js>
      // 只需在离开页面时销毁旧实例
      btf.addGlobalFn('pjaxSend', destroyAplayer, 'destroyAplayer')
    })()