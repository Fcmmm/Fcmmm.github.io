link(rel='stylesheet' href=url_for(theme.asset.aplayer_css) media="print" onload="this.media='all'")
script(src=url_for(theme.asset.aplayer_js))
script(src=url_for(theme.asset.meting_js))
//- 右下角悬浮音乐播放器 — 可拖动，跨页面不中断
#music-float-player
  meting-js(
    server="netease"
    type="playlist"
    id="2309860218"
    api="https://fcmmm.xyz/api/music?server=:server&type=:type&id=:id"
    fixed="true"
    mini="true"
    autoplay="false"
    theme="#49B1F5"
    loop="all"
    order="random"
    volume="0.7"
    list-folded="true"
    lrc-type="3"
  )

style.
  #music-float-player {
    position: fixed;
    right: 16px;
    bottom: 120px;
    z-index: 999;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }
  #music-float-player:active { cursor: grabbing; }
  #music-float-player .aplayer {
    background: rgba(255,255,255,.95) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 50px !important;
    box-shadow: 0 4px 24px rgba(0,0,0,.12);
    padding: 6px 18px 6px 6px !important;
    margin: 0 !important;
    height: auto !important;
    width: auto !important;
  }
  #music-float-player .aplayer.aplayer-fixed {
    position: static !important;
    bottom: auto !important;
    left: auto !important;
    right: auto !important;
  }
  /* 圆形封面 */
  #music-float-player .aplayer .aplayer-pic {
    width: 48px !important;
    height: 48px !important;
    border-radius: 50% !important;
    margin: 0 !important;
    flex-shrink: 0;
  }
  #music-float-player .aplayer .aplayer-pic img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    border-radius: 50% !important;
  }
  /* 精简信息区 — 只显示歌名歌手 */
  #music-float-player .aplayer .aplayer-info {
    margin-left: 10px !important;
    height: auto !important;
    padding: 0 !important;
    flex: 0 1 auto;
    max-width: 140px;
    border: none !important;
  }
  #music-float-player .aplayer .aplayer-music {
    font-size: 13px !important;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #333 !important;
    margin: 0 !important;
  }
  #music-float-player .aplayer .aplayer-music .aplayer-author {
    font-size: 11px !important;
    color: #999 !important;
    display: block;
    margin-top: 1px;
  }
  #music-float-player .aplayer .aplayer-controller {
    margin-left: 8px !important;
    display: flex !important;
    align-items: center;
    gap: 2px;
  }
  #music-float-player .aplayer .aplayer-icon {
    width: 32px !important;
    height: 32px !important;
    display: flex !important;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
    transition: opacity .2s;
  }
  #music-float-player .aplayer .aplayer-icon:hover { opacity: 1; }
  #music-float-player .aplayer .aplayer-icon svg {
    width: 18px !important;
    height: 18px !important;
  }
  /* 隐藏不需要的元素 */
  #music-float-player .aplayer .aplayer-lrc,
  #music-float-player .aplayer .aplayer-list,
  #music-float-player .aplayer .aplayer-volume,
  #music-float-player .aplayer .aplayer-icon-order,
  #music-float-player .aplayer .aplayer-icon-loop,
  #music-float-player .aplayer .aplayer-icon-lrc,
  #music-float-player .aplayer .aplayer-bar-wrap,
  #music-float-player .aplayer .aplayer-time { display: none !important; }
  /* 暗色模式 */
  [data-theme="dark"] #music-float-player .aplayer {
    background: rgba(30,30,30,.95) !important;
  }
  [data-theme="dark"] #music-float-player .aplayer .aplayer-music { color: #eee !important; }
  @media screen and (max-width: 768px) {
    #music-float-player { right: 8px; bottom: 90px; }
    #music-float-player .aplayer .aplayer-info { max-width: 100px; }
  }

script.
  // 拖动功能
  (function () {
    var el = document.getElementById('music-float-player')
    if (!el) return
    var isDragging = false, startX, startY, startLeft, startTop
    var rect

    function onDown(e) {
      if (e.target.closest('.aplayer-icon') || e.target.closest('button') || e.target.closest('input')) return
      isDragging = true
      rect = el.getBoundingClientRect()
      var t = e.touches ? e.touches[0] : e
      startX = t.clientX
      startY = t.clientY
      startLeft = rect.left
      startTop = rect.top
      el.style.transition = 'none'
      e.preventDefault()
    }

    function onMove(e) {
      if (!isDragging) return
      var t = e.touches ? e.touches[0] : e
      var dx = t.clientX - startX
      var dy = t.clientY - startY
      var newRight = window.innerWidth - (startLeft + rect.width) - dx
      var newBottom = window.innerHeight - (startTop + rect.height) - dy
      // 限制在屏幕内
      newRight = Math.max(4, Math.min(newRight, window.innerWidth - rect.width - 4))
      newBottom = Math.max(4, Math.min(newBottom, window.innerHeight - rect.height - 4))
      el.style.right = newRight + 'px'
      el.style.bottom = newBottom + 'px'
    }

    function onUp() {
      if (!isDragging) return
      isDragging = false
      el.style.transition = ''
    }

    el.addEventListener('mousedown', onDown)
    el.addEventListener('touchstart', onDown, { passive: false })
    document.addEventListener('mousemove', onMove)
    document.addEventListener('touchmove', onMove, { passive: false })
    document.addEventListener('mouseup', onUp)
    document.addEventListener('touchend', onUp)
  })()

if theme.pjax.enable
  script.
    (() => {
      const destroyAplayer = () => {
        if (window.aplayers) {
          for (let i = 0; i < window.aplayers.length; i++) {
            if (!window.aplayers[i].options.fixed) {
              window.aplayers[i].destroy()
            }
          }
        }
      }
      btf.addGlobalFn('pjaxSend', destroyAplayer, 'destroyAplayer')
    })()